# Variáveis de ambiente — Case 02 Agente Telegram

# O token gerado no BotFather do Telegram
TELEGRAM=seu_token_do_telegram_aqui

# ID do chat (para notificações automáticas sem interação). Descubra mandando mensagem pro seu bot e imprimindo o update.message.chat_id
CHAT_ID=seu_chat_id_aqui

# API Key da Groq (Llama 3) para Inteligência Artificial (gratuita)
GROQ_API_KEY=gsk_sua_chave_groq_aqui

# URL de conexão com o Supabase (PostgreSQL)
POSTGRES_URL=postgresql://postgres:[SENHA_AQUI]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres
