# Variáveis de ambiente — Case 02 Agente Telegram
# Copie este arquivo para .env e preencha os valores

# Token do bot Telegram (obtenha com @BotFather)
TELEGRAM=SEU_TOKEN_AQUI

# Chave da API do Claude (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-SUA_CHAVE_AQUI

# ID do chat para envio automático
# Deixe vazio — será preenchido automaticamente na 1ª interação com o bot
CHAT_ID=
